# Copy this file to /etc/wayside.env on the server
# Fill in the real values — NEVER commit the real wayside.env to git

ConnectionStrings__DefaultConnection=Host=localhost;Database=wayside;Username=wayside_user;Password=REPLACE_WITH_DB_PASSWORD
Jwt__Key=REPLACE_WITH_A_LONG_RANDOM_SECRET_MIN_32_CHARS

# Email (SendGrid example — free tier covers this volume)
Email__SmtpHost=smtp.sendgrid.net
Email__SmtpPort=587
Email__Username=apikey
Email__Password=REPLACE_WITH_SENDGRID_API_KEY
Email__FromAddress=noreply@waysidegarage.co.za
Email__FromName=Wayside Garage
Email__AdminEmail=ziyaad@waysidegarage.co.za
